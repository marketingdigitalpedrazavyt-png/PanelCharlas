# =========================================================
#  Copiá este archivo como .env y completá los valores.
#  (docker-compose lee .env automáticamente)
# =========================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=cambiame_root
MYSQL_DATABASE=maravillas
MYSQL_USER=maravillas
MYSQL_PASSWORD=cambiame_db

# --- Auth (backend) ---
JWT_SECRET=cambiame_por_una_cadena_larga_y_aleatoria
SUPERADMIN_EMAIL=cm@pedraza.com.ar
SUPERADMIN_PASSWORD=Pedra2026za!

# --- Marca del paquete (título de la credencial) ---
PAQUETE_NOMBRE=Maravillas del Mediterráneo
PAQUETE_BAJADA=Charla informativa exclusiva

# --- WhatsApp por n8n ---
# WHATSAPP_ENABLED=true para que el backend envie la credencial al webhook de n8n.
WHATSAPP_ENABLED=false
N8N_WEBHOOK_URL=https://tu-n8n.com/webhook/credencial-whatsapp
WHATSAPP_SESSION=default
